# ==========================================
# RAG-Scrape Environment Configurations
# Copy this file to '.env' and fill in your keys
# ==========================================

# Gemini API Key (Required for LLM router/generation and embeddings)
GEMINI_API_KEY=your-gemini-api-key-here

# Log Format (Set to 'json' to output structured JSON logs, or leave empty for console logs)
LOG_FORMAT=

# Standalone ChromaDB Server Settings (Optional)
# If CHROMA_SERVER_HOST is set, client swaps from local PersistentClient to Standalone HttpClient
# CHROMA_SERVER_HOST=localhost
# CHROMA_SERVER_PORT=8000

# LangFuse Observability Keys (Optional, fill in to enable pipeline tracing)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
